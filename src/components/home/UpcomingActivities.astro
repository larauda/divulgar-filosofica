---
import { getCollection } from 'astro:content';

const activities = (await getCollection('activities')).sort((a, b) => {
  const dateA = a.data.date?.getTime() ?? 0;
  const dateB = b.data.date?.getTime() ?? 0;

  return dateB - dateA;
});

const formatDate = (date?: Date) => {
  if (!date) return '';

  return new Intl.DateTimeFormat('es-CL', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(date);
};

const today = new Date();
today.setHours(0, 0, 0, 0);

const getActivityUrl = (id: string) => {
  const slug = id.replace(/\.(md|mdx)$/, '');

  return `/actividades/${slug}`;
};

const getGalleryUrl = (gallery?: string) => {
  if (!gallery) return undefined;

  return `/galeria/${gallery}`;
};

const isUpcomingActivity = (date?: Date) => {
  if (!date) return false;

  const activityDate = new Date(date);
  activityDate.setHours(0, 0, 0, 0);

  return activityDate >= today;
};

const isFinishedActivity = (date?: Date) => {
  if (!date) return false;

  const activityDate = new Date(date);
  activityDate.setHours(0, 0, 0, 0);

  return activityDate < today;
};

const hasValidRegistrationUrl = (registrationUrl?: string) => {
  return (
    typeof registrationUrl === 'string' &&
    registrationUrl.trim() !== '' &&
    registrationUrl.trim() !== '#'
  );
};
---

<section class="activities-section bg-[#f8f5f0] py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">

    <!-- Encabezado -->
    <div class="mx-auto mb-14 max-w-3xl text-center">
      <p class="activities-label mb-4 uppercase tracking-[0.22em] text-[#79558c]">
        Actividades
      </p>

      <h2 class="activities-title leading-tight text-[#214536]">
        Pensar juntas también es construir comunidad.
      </h2>

      <p class="activities-intro mx-auto mt-6 max-w-2xl leading-relaxed text-[#4f5f58]">
        Conoce nuestros talleres, encuentros, charlas y espacios de reflexión
        colectiva.
      </p>
    </div>

    {
      activities.length > 0 ? (
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
          {activities.map((activity) => {
            const activityUrl = getActivityUrl(activity.id);
            const galleryUrl = getGalleryUrl(activity.data.gallery);

            const isUpcoming = isUpcomingActivity(activity.data.date);
            const isFinished = isFinishedActivity(activity.data.date);

            const canRegister =
              isUpcoming &&
              hasValidRegistrationUrl(activity.data.registrationUrl);

            const canViewGallery =
              isFinished &&
              Boolean(galleryUrl);

            const activityStatus = isFinished
              ? 'Actividad realizada'
              : activity.data.status || 'Próximamente';

            return (
              <article class="activity-card group flex h-full flex-col overflow-hidden rounded-[2rem] bg-white shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-xl">

                <!-- Imagen -->
                <div class="h-72 overflow-hidden bg-[#e9e4dc]">
                  <img
                    src={activity.data.image}
                    alt={activity.data.title}
                    loading="lazy"
                    class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                  />
                </div>

                <!-- Contenido -->
                <div class="flex flex-1 flex-col p-7">

                  <!-- Etiquetas -->
                  <div class="mb-5 flex flex-wrap gap-2">
                    <span class="activity-tag rounded-full bg-[#214536] px-4 py-2 uppercase tracking-wider text-white">
                      {activity.data.type}
                    </span>

                    <span class="activity-tag rounded-full bg-[#eee6f1] px-4 py-2 uppercase tracking-wider text-[#79558c]">
                      {activityStatus}
                    </span>
                  </div>

                  <!-- Título -->
                  <h3 class="activity-card-title leading-snug text-[#214536]">
                    {activity.data.title}
                  </h3>

                  <!-- Descripción -->
                  {
                    activity.data.excerpt && (
                      <p class="activity-description mt-4 leading-relaxed text-[#58645f]">
                        {activity.data.excerpt}
                      </p>
                    )
                  }

                  <!-- Detalles -->
                  <div class="activity-details mt-6 space-y-2 text-[#52605a]">
                    {
                      activity.data.date && (
                        <p>
                          <strong class="text-[#214536]">Fecha:</strong>{' '}
                          {formatDate(activity.data.date)}
                        </p>
                      )
                    }

                    {
                      activity.data.modality && (
                        <p>
                          <strong class="text-[#214536]">Modalidad:</strong>{' '}
                          {activity.data.modality}
                        </p>
                      )
                    }

                    {
                      activity.data.location && (
                        <p>
                          <strong class="text-[#214536]">Lugar:</strong>{' '}
                          {activity.data.location}
                        </p>
                      )
                    }
                  </div>

                  <!-- Botones -->
                  <div class="mt-auto flex flex-wrap gap-3 pt-8">

                    {
                      canRegister ? (
                        <a
                          href={activity.data.registrationUrl}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="activity-button inline-flex items-center justify-center rounded-full bg-[#79558c] px-5 py-3 text-white transition hover:bg-[#62406f]"
                        >
                          Inscribirse
                        </a>
                      ) : canViewGallery ? (
                        <a
                          href={galleryUrl}
                          class="activity-button inline-flex items-center justify-center rounded-full bg-[#214536] px-5 py-3 text-white transition hover:bg-[#173228]"
                        >
                          Ver galería de imágenes
                        </a>
                      ) : isUpcoming ? (
                        <span
                          class="activity-button inline-flex cursor-default items-center justify-center rounded-full bg-[#eee9e3] px-5 py-3 text-[#66716c]"
                        >
                          Próximamente
                        </span>
                      ) : (
                        <span
                          class="activity-button inline-flex cursor-default items-center justify-center rounded-full bg-[#eee9e3] px-5 py-3 text-[#66716c]"
                        >
                          Actividad realizada
                        </span>
                      )
                    }

                    <a
                      href={activityUrl}
                      class="activity-button inline-flex items-center justify-center rounded-full border border-[#79558c] px-5 py-3 text-[#79558c] transition hover:bg-[#79558c] hover:text-white"
                    >
                      Ver actividad
                    </a>

                  </div>
                </div>
              </article>
            );
          })}
        </div>
      ) : (
        <div class="rounded-[2rem] bg-white px-6 py-16 text-center shadow-sm">
          <p class="activities-intro text-[#58645f]">
            Próximamente publicaremos nuevas actividades.
          </p>
        </div>
      )
    }
  </div>
</section>

<style>
  .activities-section {
    font-family: 'Lato', sans-serif;
  }

  .activities-label {
    font-family: 'Lato', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
  }

  .activities-title {
    font-family: 'Satisfy', cursive;
    font-size: clamp(2.8rem, 5vw, 4.7rem);
    font-weight: 400;
  }

  .activities-intro {
    font-family: 'Lato', sans-serif;
    font-size: 1.1rem;
  }

  .activity-card-title {
    font-family: 'Lato', sans-serif;
    font-size: 1.55rem;
    font-weight: 700;
  }

  .activity-description {
    font-family: 'Lato', sans-serif;
    font-size: 1rem;
  }

  .activity-details {
    font-family: 'Lato', sans-serif;
    font-size: 0.9rem;
  }

  .activity-tag {
    font-family: 'Lato', sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
  }

  .activity-button {
    font-family: 'Lato', sans-serif;
    font-size: 0.88rem;
    font-weight: 700;
  }
</style>