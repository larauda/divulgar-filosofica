---
import Angela from '~/assets/images/activities/angela-davis.jpeg';
import Rita from '~/assets/images/activities/rita-segato.png';
import Silvia from '~/assets/images/activities/silvia-federici.png';

const activities = [
  {
    image: Angela,
    title: 'Cuando la igualdad no alcanza',
    author: 'Angela Davis',
    date: 'Próxima edición',
    place: 'Concepción',
  },
  {
    image: Rita,
    title: 'Contra pedagogías de la crueldad',
    author: 'Rita Segato',
    date: 'Próxima edición',
    place: 'Concepción',
  },
  {
    image: Silvia,
    title: 'Maternidad y el castigo del capitalismo',
    author: 'Silvia Federici',
    date: 'Archivo',
    place: 'Concepción',
  },
];
---

<section class="py-32 bg-[#F8F5F0]">

  <div class="max-w-7xl mx-auto px-8">

    <div class="text-center mb-20">

   <h2
  class="text-[#214536] mb-6"
  style="font-family:'Satisfy', cursive;"
>
  <span class="block text-[4rem] leading-[0.9]">
    Pensar juntas
  </span>

  <span class="block text-[3.2rem] leading-[0.95]">
    también es construir comunidad.
  </span>
</h2>

      <p class="text-[17px] leading-7 text-stone-600 max-w-2xl mx-auto">
        Talleres, grupos de estudio y encuentros abiertos para reflexionar colectivamente desde una perspectiva crítica y feminista.
      </p>

    </div>

    <div class="grid lg:grid-cols-3 gap-10">

      {
        activities.map((activity) => (

            <article class="group transition duration-300 hover:-translate-y-3">
  <div
    class={`overflow-hidden rounded-[28px] shadow-lg bg-white transition-all duration-500 group-hover:rotate-0 group-hover:shadow-xl ${
      activity.author === 'Angela Davis'
        ? 'rotate-[-2deg]'
        : activity.author === 'Rita Segato'
          ? 'rotate-[2deg]'
          : 'rotate-[-1deg]'
    }`}
  >
    <img
      src={activity.image.src}
      alt={activity.title}
      class="w-full"
    />
  </div>

  <div class="mt-7">
    <p class="text-xs uppercase tracking-[0.35em] text-[#A05BEA] mb-2">
      {activity.date}
    </p>

    <h3 class="text-[28px] leading-8 text-[#214536] mb-2 font-bold">
      {activity.title}
    </h3>

    <p class="text-stone-500 mb-5">
      {activity.author}
    </p>

    <a
      href="/actividades"
      class="font-semibold text-[#214536] hover:text-[#A05BEA] transition"
    >
      Ver actividad →
    </a>
  </div>
</article>


        ))
      }

    </div>

    <div class="text-center mt-20">

      <a
        href="/actividades"
        class="inline-flex bg-[#A05BEA] text-white px-8 py-4 rounded-full hover:bg-[#8E4DE8] transition"
      >
        Ver todas las actividades
      </a>

    </div>

  </div>

</section>