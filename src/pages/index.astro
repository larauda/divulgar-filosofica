---
import Layout from '~/layouts/PageLayout.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';

import Hero from '~/components/home/Hero.astro';
import WhatWeDo from '~/components/home/WhatWeDo.astro';
import Vision from '~/components/home/Vision.astro';
import UpcomingActivities from '~/components/home/UpcomingActivities.astro';
import LatestReflections from '~/components/home/LatestReflections.astro';
import Footer from '~/components/home/Footer.astro';


const metadata = {
  title: 'Divulgar Filosófica',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Hero />
  <WhatWeDo />
  <Vision />
  <UpcomingActivities />
  <LatestReflections />



<!-- CTA -->
<section class="py-28 bg-[#214536] text-white">
  <div class="max-w-4xl mx-auto px-8 text-center">
    <h2
      class="text-[3.2rem] leading-[1] mb-8"
      style="font-family:'Satisfy', cursive;"
    >
      Conversemos
    </h2>

   <p class="text-[24px] leading-9 text-white font-medium mb-6 max-w-3xl mx-auto">
  ¿Te interesa realizar una charla, taller, grupo de estudio o mediación filosófica en tu comunidad, organización o espacio educativo?
</p>

<p class="text-[18px] leading-8 text-white/80 mb-10 max-w-2xl mx-auto">
  Podemos desarrollar una propuesta adaptada a tus necesidades e intereses.
</p>

    <a
      href="mailto:divulgar.filosofica@gmail.com?subject=Consulta%20desde%20Divulgar%20Filosófica"
      class="inline-flex bg-[#A05BEA] text-white px-7 py-3 rounded-full text-sm font-medium hover:bg-[#8E4DE8] transition duration-300"
    >
      Conversemos →
    </a>
  </div>
</section>

  <Footer />
</Layout>